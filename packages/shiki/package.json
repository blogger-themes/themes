      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "dependencies": {
    "@deox/worker-rpc": "^0.0.21",
    "@shikijs/langs": "^4.1.0",
    "@shikijs/themes": "^4.1.0",
    "@shikijs/transformers": "^4.1.0",
    "@themes/utils": "workspace:*",
    "shiki": "^4.1.0",
    "style-to-js": "^2.0.0"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  }
}
