{
  "name": "@themes/utils",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "biome lint ./src",
    "check": "biome check ./src",
    "check:types": "tsc --noEmit",
    "build": "NODE_ENV=production tsdown",
    "dev": "NODE_ENV=development tsdown --watch"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "devDependencies": {
    "tsdown": "catalog:"
  }
}
