{
  "name": "react-blogger-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12"
  },
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "format": "biome format --max-diagnostics=100 --log-kind=compact .",
    "format:fix": "pnpm run format --write",
    "lint": "biome lint --max-diagnostics=100 --log-kind=compact .",
    "lint:fix": "pnpm run lint --write",
    "check": "biome check --max-diagnostics=150 --log-kind=compact .",
    "check:fix": "pnpm run check --write",
    "check:types": "tsc --noEmit --project ./tsconfig.app.json",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "upgrade": "pnpm dlx npm-check-updates@latest --peer --interactive --format group"
  },
  "dependencies": {
    "@deox/dom-to-react": "^0.0.4",
    "@deox/google-image": "^0.0.2",
    "@deox/utils": "^0.0.4",
    "@deox/worker-rpc": "^0.0.18",
    "@fontsource-variable/inclusive-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.11.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "style-to-js": "^1.1.21",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "blogger-plugin": "^0.0.8",
    "shadcn": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
