{
  "name": "react-blogger-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "format": "biome format --max-diagnostics=100 --log-kind=compact .",
    "format:fix": "pnpm run format --write",
    "lint": "biome lint --max-diagnostics=100 --log-kind=compact .",
    "lint:fix": "pnpm run lint --write",
    "check": "biome check --max-diagnostics=150 --log-kind=compact .",
    "check:fix": "pnpm run check --write",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "upgrade": "pnpm dlx npm-check-updates --peer --interactive --format group"
  },
  "dependencies": {
    "@deox/google-image": "^0.0.1",
    "@fontsource-variable/inclusive-sans": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.552.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "blogger-plugin": "^0.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
