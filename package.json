{
  "name": "react-blogger-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "format": "biome format --max-diagnostics=100 --log-kind=compact .",
    "format:fix": "pnpm run format --write",
    "lint": "biome lint --max-diagnostics=100 --log-kind=compact .",
    "lint:fix": "pnpm run lint --write",
    "check": "biome check --max-diagnostics=150 --log-kind=compact .",
    "check:fix": "pnpm run check --write",
    "check:types": "tsc --noEmit --project ./tsconfig.app.json",
    "dev": "tsdown && vite",
    "build": "tsdown && tsc -b && vite build",
    "preview": "vite preview",
    "upgrade": "pnpm dlx npm-check-updates@latest --peer --interactive --format group"
  },
  "dependencies": {
    "@deox/dom-to-react": "^0.0.5",
    "@deox/google-image": "^0.0.3",
    "@deox/utils": "^0.0.5",
    "@deox/worker-rpc": "^0.0.19",
    "@fontsource-variable/inclusive-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0",
    "schema-dts": "^2.0.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "style-to-js": "^1.1.21",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@tsdown/css": "^0.22.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "blogger-plugin": "^0.0.11",
    "shadcn": "^4.7.0",
    "tsdown": "^0.22.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
