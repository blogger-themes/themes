{
  "name": "react-blogger-template",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.29.1",
  "type": "module",
  "scripts": {
    "format": "biome format --max-diagnostics=100 --log-kind=compact .",
    "format:fix": "pnpm run format --write",
    "lint": "biome lint --max-diagnostics=100 --log-kind=compact .",
    "lint:fix": "pnpm run lint --write",
    "check": "biome check --max-diagnostics=150 --log-kind=compact .",
    "check:fix": "pnpm run check --write",
    "check:types": "tsc --noEmit --project ./tsconfig.app.json",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "upgrade": "pnpm dlx npm-check-updates --peer --interactive --format group"
  },
  "dependencies": {
    "@deox/dom-to-react": "^0.0.4",
    "@deox/google-image": "^0.0.2",
    "@deox/utils": "^0.0.4",
    "@deox/worker-rpc": "^0.0.18",
    "@fontsource-variable/inclusive-sans": "^5.2.8",
    "@shikijs/langs": "^3.22.0",
    "@shikijs/themes": "^3.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.9.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.1",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "shiki": "^3.22.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "blogger-plugin": "^0.0.2",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.0"
  }
}
